# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# JWT Secret (Generar en producción con: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-min-32-chars

# Google Gemini API Key
GOOGLE_API_KEY=your-google-api-key

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
# Reemplaza con la URL real de Vercel cuando esté deployado
CORS_ORIGINS=http://localhost:3000,https://tu-proyecto.vercel.app
MAX_FILE_SIZE_MB=20
MAX_CACHE_SIZE=1000
