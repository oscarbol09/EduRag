# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# JWT Secret (Generar en producción con: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-min-32-chars

# Cifrado de API keys de docentes con Fernet (CRÍTICO en producción)
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Si se omite, se deriva automáticamente de JWT_SECRET (menos seguro)
ENCRYPTION_KEY=

# OpenRouter API Key (fallback para cuentas @edurag.com — cada docente pone la suya en Settings)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Modelo LLM por defecto si el docente no tiene uno configurado
DEFAULT_LLM_MODEL=google/gemma-3-27b-it:free

# Emails autorizados a usar la API key del sistema (comma-separated, sin espacios)
TEST_ACCOUNTS_WHITELIST=admin@edurag.com,test@edurag.com

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
# Reemplaza con la URL real de Vercel cuando esté deployado
CORS_ORIGINS=http://localhost:3000,https://tu-proyecto.vercel.app
MAX_FILE_SIZE_MB=20
MAX_CACHE_SIZE=1000
